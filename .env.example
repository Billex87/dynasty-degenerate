JWT_SECRET=
DATABASE_URL=
ADMIN_LOGIN_PASSWORD=

# Comma-, space-, or newline-separated identifiers that may unlock
# report admin-only views without shipping the list to the client.
# Accepts Sleeper usernames/display names/user IDs for report access.
ADMIN_PERMISSIONS=

# Optional fantasy ranking sources. FantasyPros now supports redraft, dynasty,
# devy, rookie, ADP, news, injuries, and historical points checks behind
# server-only env keys/flags. Fleaflicker requires a public league context for
# its official player-listing API.
FANTASYPROS_API_KEY=
FANTASY_NERDS_API_KEY=
# Approved-access only. Configure from DraftSharks partner/control-panel REST
# docs; do not scrape public DraftSharks pages.
ENABLE_DRAFTSHARKS_SOS=
DRAFTSHARKS_API_KEY=
DRAFTSHARKS_SOS_URL=
# Optional access probes for approved/credentialed source research. These are
# server-only and should feed nightly snapshots, not normal report loads.
YAHOO_ACCESS_TOKEN=
OPTICODDS_API_KEY=
SPORTSGAMEODDS_API_KEY=
PARLAY_API_KEY=
SOURCE_PROBE_TIMEOUT_MS=12000
ENABLE_OPTICODDS_PLAYER_PROPS=
OPTICODDS_FIXTURE_LIMIT=8
OPTICODDS_SPORTSBOOKS=sleeper,bet365,underdog_fantasy_2_pick_
OPTICODDS_PROP_MARKETS=player_passing_yards,player_rushing_yards,player_receiving_yards,player_receptions,player_anytime_touchdown
# Fantasy Nerds falls back to the public TEST key in development when no real
# API key is configured. Set this to true to force that behavior elsewhere.
ENABLE_FANTASY_NERDS_TEST_DATA=
FLEAFLICKER_LEAGUE_ID=
FLEAFLICKER_SEASON=
RANKINGS_SEASON=2026
FANTASYPROS_RANKINGS_SEASON=

# Optional source controls. Leave blank/true to enable; set false, 0, off, no,
# or disabled to skip a source during report generation. In production,
# Yahoo/NFL scraping fallbacks are disabled unless explicitly set to true.
ENABLE_DYNASTY_ADAPTIVE_TRUST=
ENABLE_DEVY_ADAPTIVE_TRUST=
ENABLE_DEVY_SOURCE_SNAPSHOTS=
ENABLE_LEAGUE_AI_CONFIDENCE_SNAPSHOTS=
ENABLE_SOURCE_HEALTH_BACKFILL=
SOURCE_HEALTH_ALERT_WEBHOOK_URL=
SOURCE_HEALTH_ALERT_WEBHOOK_MIN_LEVEL=warn
NFL_SEASON_START_DATE=
REDRAFT_SOURCE_TIMEOUT_MS=8000
ENABLE_REDRAFT_ADAPTIVE_TRUST=
ENABLE_REDRAFT_SOURCE_SNAPSHOTS=
ENABLE_REDRAFT_FANTASYPROS=
ENABLE_FANTASYPROS_DRAFT_RANKINGS=
ENABLE_FANTASYPROS_ROS_RANKINGS=
ENABLE_FANTASYPROS_DYNASTY_RANKINGS=
ENABLE_FANTASYPROS_DEVY_RANKINGS=
ENABLE_FANTASYPROS_ROOKIE_RANKINGS=
ENABLE_FANTASYPROS_ADP_RANKINGS=
ENABLE_FANTASYPROS_PROJECTIONS=
ENABLE_FANTASYPROS_INJURIES=
ENABLE_FANTASYPROS_NEWS=
ENABLE_FANTASYPROS_PLAYER_POINTS=
# Opt into broader FantasyPros endpoint health probes only after API limits are
# understood; health checks are paced and stop on 429s.
ENABLE_FANTASYPROS_EXPANDED_HEALTH=
FANTASYPROS_HEALTH_REQUEST_DELAY_MS=750
ENABLE_FANTASYPROS_ENDPOINT_SNAPSHOTS=
ENABLE_FANTASYPROS_EXPANDED_SNAPSHOTS=
FANTASYPROS_SNAPSHOT_REQUEST_DELAY_MS=750
# Endpoint snapshots normally run from the weekly Tuesday noon cron. Set this
# only if package limits prove the FantasyPros endpoint payload scrape is cheap
# enough to run during the daily dynamic-data refresh.
ENABLE_FANTASYPROS_ENDPOINT_SNAPSHOTS_DAILY=
# Fallback only; scheduled refreshes use Sleeper NFL state when it matches the
# ranking season. Set FORCE only for manual backfills or endpoint probes.
FANTASYPROS_SNAPSHOT_START_WEEK=1
FANTASYPROS_SNAPSHOT_FORCE_START_WEEK=
FANTASYPROS_SNAPSHOT_WEEK_WINDOW=3
ENABLE_REDRAFT_FANTASY_NERDS=
ENABLE_REDRAFT_FLOCK_BEST_BALL=
ENABLE_REDRAFT_INTERNAL_SEASON_BLEND=
ENABLE_REDRAFT_MFL_ADP=
ENABLE_REDRAFT_MFL_RANKINGS=
ENABLE_REDRAFT_ESPN=
ENABLE_REDRAFT_FLEAFLICKER=
ENABLE_REDRAFT_YAHOO=
ENABLE_REDRAFT_NFL=
